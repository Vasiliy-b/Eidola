# =============================================================================
# GOOGLE CLOUD / VERTEX AI CONFIGURATION
# =============================================================================
GOOGLE_GENAI_USE_VERTEXAI=TRUE
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=global
GOOGLE_CLOUD_QUOTA_PROJECT=your-gcp-project-id

# =============================================================================
# MONGODB CONFIGURATION
# =============================================================================
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=eidola

# =============================================================================
# FIRERPA DEVICE CONFIGURATION
# =============================================================================
FIRERPA_DEVICE_IP=192.168.1.10

# =============================================================================
# PROXY CONFIGURATION (Decodo/Smartproxy or any HTTP CONNECT provider)
# =============================================================================
DECODO_USERNAME=your_proxy_username
DECODO_PASSWORD=your_proxy_password

# =============================================================================
# AGENT CONFIGURATION
# =============================================================================
DEFAULT_MODEL=gemini-3-flash-preview
DEFAULT_TEMPERATURE=1.0

# =============================================================================
# GMAIL ACCOUNTS (for Play Store / 2FA recovery)
# =============================================================================
GMAIL_PASS_PHONE_01=your_gmail_password
GMAIL_TOTP_PHONE_01=your_gmail_totp_secret

# =============================================================================
# INSTAGRAM ACCOUNTS
# =============================================================================
# One pair per account. The env var name must match password_env/totp_secret_env
# in the account's YAML config (config/accounts/*.yaml).
IG_PASS_EXAMPLE_ACCOUNT=your_instagram_password
IG_TOTP_EXAMPLE_ACCOUNT=your_instagram_totp_secret

# =============================================================================
# Telegram Bot (Content Distribution)
# =============================================================================
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather

# =============================================================================
# Content Storage
# =============================================================================
CONTENT_DIR=./data/content
